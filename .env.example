# APOLLO configuration
# Copy this file to .env and adjust values as needed.

# Ollama LLM endpoint
OLLAMA_BASE_URL=http://localhost:11434/v1

# Model name to use for AI screening
OLLAMA_MODEL=qwen2.5:7b

# SQLite database path (default: data/processed/screening.db)
# APOLLO_DB_PATH=data/processed/screening.db

# LLM base URL override (optional, falls back to OLLAMA_BASE_URL)
# APOLLO_LLM_BASE_URL=

# LLM model override (optional, falls back to OLLAMA_MODEL)
# APOLLO_LLM_MODEL=
